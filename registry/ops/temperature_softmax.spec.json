{
  "id": "temperature_softmax@1.0.0",
  "name": "temperature-scaled row-wise softmax",
  "version": "1.0.0",
  "kernel": "temperature_softmax",
  "op": {
    "signature": "probs[B,V] fp32 = softmax(logits[B,V] / temperatures[B])",
    "canonical_op": "reduce",
    "fusions": []
  },
  "inputs": {
    "logits": {
      "dtype": [
        "fp32",
        "bf16",
        "fp16"
      ],
      "rank": 2,
      "layout": "row_major",
      "shape_symbols": [
        "B",
        "V"
      ]
    },
    "temperatures": {
      "dtype": [
        "fp32"
      ],
      "rank": 1,
      "layout": "row_major",
      "shape_symbols": [
        "B"
      ]
    }
  },
  "outputs": {
    "probs": {
      "dtype": [
        "fp32"
      ],
      "rank": 2,
      "layout": "row_major",
      "shape_symbols": [
        "B",
        "V"
      ]
    }
  },
  "constraints": [],
  "preconditions": [
    "temperatures are positive and finite",
    "top-k/top-p selection and RNG sampling are intentionally outside this DSL op",
    "current rowwise Triton lowering reduces one full row per program; full 100k+ vocab sampling needs a staged streaming follow-up"
  ],
  "numerics": {
    "reference": "xkernels.vkl.auto:temperature_softmax",
    "rtol": 0.006,
    "atol": 0.001,
    "reduce_dtype": "fp32",
    "cross_backend_rtol": 0.006,
    "by_dtype": {
      "fp32": {
        "rtol": 0.006,
        "atol": 0.001
      },
      "bf16": {
        "rtol": 0.006,
        "atol": 0.001
      },
      "fp16": {
        "rtol": 0.006,
        "atol": 0.001
      }
    },
    "notes": "Stable row-wise softmax prefix for sampling/top-k gating. Logits and temperature divide promote to fp32; max and sum reductions are fp32. Tolerance covers Triton tl.exp approximation vs torch.exp on GB10 (observed max_abs < 8e-4, max_rel < 5.2e-3). Value-dependent top-k/top-p and RNG sampling stay hand-path."
  },
  "shape_sweep": "temperature_softmax",
  "composes_with": [],
  "provenance": {
    "authored_by": "dsl",
    "source_path": "xkernels.vkl:temperature_softmax"
  }
}
