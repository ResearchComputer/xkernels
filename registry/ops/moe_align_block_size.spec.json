    "num_tokens_post_padded": { "dtype": ["int32"], "layout": "scalar", "rank": 1 }
  },
  "constraints": [
    "block_size > 0",
    "num_experts > 0"
  ],
  "preconditions": ["topk_ids in [0, num_experts)"],
  "numerics": {
    "reference": "xkernels.ops.moe.w4a16:moe_align_block_size_ref",
    "rtol": 0.0,
    "atol": 0.0,
    "cross_backend_rtol": 0.0,
    "notes": "Integer dispatch builder; correctness is bit-for-bit (exact equality), hence rtol=atol=0. Validated as a set-equality + ordering match, not float closeness."
  },
  "shape_sweep": "moe_align_block_size",
  "composes_with": ["moe_int4_w4a16@1.0.0"]
}
