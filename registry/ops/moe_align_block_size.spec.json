{
  "id": "moe_align_block_size@1.0.0",
  "name": "sort/pad routed token-slots into per-expert blocks",
  "version": "1.0.0",
  "kernel": "moe_align_block_size",
  "op": {
    "signature": "(sorted_token_ids, expert_ids, num_tokens_post_padded) = align(topk_ids, block_size, num_experts)",
    "canonical_op": "scatter",
    "fusions": ["histogram", "padded_prefix_sum"]
  },
  "inputs": {
    "topk_ids":    { "dtype": ["int32"], "layout": "row_major", "rank": 2, "shape_symbols": ["M", "top_k"] },
    "block_size":  { "dtype": ["int32"], "layout": "scalar", "rank": 0, "shape_symbols": [] },
    "num_experts": { "dtype": ["int32"], "layout": "scalar", "rank": 0, "shape_symbols": [] }
  },
  "outputs": {
    "sorted_token_ids":     { "dtype": ["int32"], "layout": "row_major", "rank": 1 },
