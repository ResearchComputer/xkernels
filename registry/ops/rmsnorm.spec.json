{
  "id": "rmsnorm@1.0.0",
  "name": "plain single-tensor RMSNorm",
  "version": "1.0.0",
  "kernel": "rmsnorm",
  "op": {
    "signature": "out[T,d] = (x[T,d] * rsqrt(mean(x^2)[T] + eps)) * w[d], fp32 reduce",
    "canonical_op": "norm",
    "fusions": []
  },
  "inputs": {
    "x": {
      "dtype": [
        "fp32",
        "bf16",
        "fp16"
      ],
      "rank": 2,
      "layout": "row_major",
      "shape_symbols": [
        "T",
        "d"
      ]
    },
    "w": {
      "dtype": [
        "fp32",
        "bf16",
        "fp16"
      ],
      "rank": 1,
      "layout": "row_major",
      "shape_symbols": [
        "d"
      ]
    }
  },
  "outputs": {
    "out": {
      "dtype": [
        "fp32",
        "bf16",
        "fp16"
      ],
      "rank": 2,
      "layout": "row_major",
      "shape_symbols": [
        "T",
        "d"
      ]
    }
  },
  "constraints": [
    "dtype(x) == dtype(w)"
  ],
  "preconditions": [
    "x is contiguous row-major",
    "eps = 1e-6 baked into the kernel"
  ],
  "numerics": {
    "reference": "xkernels.vkl.auto:rmsnorm",
    "rtol": 0.016,
    "atol": 0.01,
    "reduce_dtype": "fp32",
    "cross_backend_rtol": 0.016,
    "by_dtype": {
      "fp32": {
        "rtol": 1e-05,
        "atol": 1e-06
      },
      "bf16": {
        "rtol": 0.016,
        "atol": 0.01
      },
      "fp16": {
        "rtol": 0.016,
        "atol": 0.01
      }
    },
    "notes": "Variance reduced in fp32 (rsqrt of fp32 mean-of-squares); identical numerics to dual_rmsnorm's per-latent branch. eps=1e-6 baked (Llama/DeepSeek default)."
  },
  "shape_sweep": "rmsnorm",
  "composes_with": [],
  "provenance": {
    "authored_by": "dsl",
    "source_path": "xkernels.vkl:rmsnorm"
  }
}
